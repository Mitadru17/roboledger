# ═══════════════════════════════════════════════════
# RoboLedger — Environment Configuration
# ═══════════════════════════════════════════════════
# Copy this file to .env and customize as needed.

# Solana Network
SOLANA_RPC_URL=https://api.devnet.solana.com
NETWORK=devnet

# Robot Identity
ROBOT_NAME=RoboAgent-Alpha
ROBOT_ID=ROBO-001
ROBOT_MODEL=RoboLedger-X1

# Wallet (auto-generated if missing)
WALLET_PATH=wallet/keypair.json

# Robot Physical Params
INITIAL_BATTERY=100.0
BATTERY_DRAIN_RATE=0.8
MIN_BATTERY_THRESHOLD=15.0
ROBOT_SPEED=2.5

# Starting Coordinates (SF campus default)
INITIAL_LAT=37.7749
INITIAL_LON=-122.4194

# Task Marketplace
TASK_SCAN_INTERVAL=2.0
MAX_TASK_DISTANCE=50.0
MIN_REWARD_SOL=0.05
NUM_DEMO_TASKS=3

# Bid Config
BID_ACCEPTANCE_RATE=0.95
BID_RESPONSE_TIME=1.5

# Settlement
PLATFORM_FEE_RATE=0.05
SLASHING_RATE=0.25
FAILURE_PROBABILITY=0.10

# Demo Speed (1.0 = normal, 0.5 = fast, 2.0 = slow)
DEMO_SPEED=1.0

# Logging
LOG_LEVEL=INFO
LOG_TO_FILE=true
